.MAKE: $(am__recursive_targets) install-am install-strip

.PHONY: $(am__recursive_targets) CTAGS GTAGS TAGS all all-am check \
	check-am check-valgrind-am check-valgrind-drd-am \
	check-valgrind-drd-local check-valgrind-helgrind-am \
	check-valgrind-helgrind-local check-valgrind-local \
	check-valgrind-memcheck-am check-valgrind-memcheck-local \
	check-valgrind-sgcheck-am check-valgrind-sgcheck-local clean \
	clean-generic clean-libtool cscopelist-am ctags ctags-am \
	distclean distclean-generic distclean-libtool distclean-local \
	distclean-tags distdir dvi dvi-am html html-am info info-am \
	install install-am install-data install-data-am install-dvi \
	install-dvi-am install-exec install-exec-am install-html \
	install-html-am install-info install-info-am install-man \
	install-pdf install-pdf-am install-ps install-ps-am \
	install-strip installcheck installcheck-am installdirs \
	installdirs-am maintainer-clean maintainer-clean-generic \
	mostlyclean mostlyclean-generic mostlyclean-libtool pdf pdf-am \
	ps ps-am tags tags-am uninstall uninstall-am

.PRECIOUS: Makefile


@HAVE_SWIG_PERL_TRUE@all-am: $(dist_perl_PERL)
@HAVE_SWIG_PERL_TRUE@	@echo Making all for perl

# building perl bindings is optional. Most setup's don't have all the deps, like
# crypt.h, sys/wait.h on windows.
# grep rem: with a command.com compat Makefile we cannot continue from bash
@HAVE_SWIG_PERL_TRUE@perl/LibreDWG.$(OBJEXT): perl/LibreDWG.pm perl/Makefile
@HAVE_SWIG_PERL_TRUE@	@echo Note LibreDWG.c is huge. This will need some time...
@HAVE_SWIG_PERL_TRUE@	-if test -f perl/pm_to_blib; then rm perl/pm_to_blib; fi
@HAVE_SWIG_PERL_TRUE@	-if test -d perl/blib; then rm -rf perl/blib; fi
@HAVE_SWIG_PERL_TRUE@	-if grep "NOOP = rem" perl/Makefile; then false; else \
@HAVE_SWIG_PERL_TRUE@	    cd perl && $(MAKE) PERL="$(PERL)" \
@HAVE_SWIG_PERL_TRUE@	                       OPTIMIZE="-I$(abs_top_srcdir)/include -I$(abs_top_builddir)/src" \
@HAVE_SWIG_PERL_TRUE@	                       OTHERLDFLAGS="-L$(abs_top_builddir)/src/.libs"; fi

@HAVE_SWIG_PERL_TRUE@perl/Makefile: perl/Makefile.PL
@HAVE_INSRCDIR_FALSE@@HAVE_SWIG_PERL_TRUE@	-mkdir -p perl/t
@HAVE_INSRCDIR_FALSE@@HAVE_SWIG_PERL_TRUE@	-cp -f $(srcdir)/perl/t/0_basic.t perl/t/
@HAVE_SWIG_PERL_TRUE@	-cd perl && \
@HAVE_SWIG_PERL_TRUE@	  $(PERL) Makefile.PL PERL="$(PERL)" INSTALLDIRS=@with_perl_install@

# Maybe disable if LibreDWG.so was not installed yet.
# rpath/LD_LIBRARY_PATH overrides are too troublesome
@HAVE_SWIG_PERL_TRUE@check-am: $(dist_perl_PERL) perl/Makefile perl/LibreDWG.$(OBJEXT)
@HAVE_SWIG_PERL_TRUE@	@echo Making check for perl
@HAVE_SWIG_PERL_TRUE@	-if grep "NOOP = rem" perl/Makefile; then false; else \
@HAVE_SWIG_PERL_TRUE@	    LD_LIBRARY_PATH="$(abs_top_builddir)/src/.libs" $(MAKE) -C perl test \
@HAVE_SWIG_PERL_TRUE@	      PERL="$(PERL)" OPTIMIZE="-I$(abs_top_srcdir)/include -I$(abs_top_builddir)/src" \
@HAVE_SWIG_PERL_TRUE@              OTHERLDFLAGS="-L$(abs_top_builddir)/src/.libs"; fi

@HAVE_SWIG_PERL_TRUE@install-am: $(dist_perl_PERL) perl/Makefile perl/LibreDWG.$(OBJEXT)
@HAVE_SWIG_PERL_TRUE@	@echo Making install for perl
@HAVE_SWIG_PERL_TRUE@	-if test x@with_perl_install@ != xno; then if grep "NOOP = rem" perl/Makefile; \
@HAVE_SWIG_PERL_TRUE@            then false; \
@HAVE_SWIG_PERL_TRUE@	    else $(MAKE) -C perl install_@with_perl_install@ PERL="$(PERL)"; fi; fi

@HAVE_SWIG_PERL_TRUE@clean-am:
@HAVE_SWIG_PERL_TRUE@	-$(MAKE) -C perl clean

@HAVE_SWIG_PERL_TRUE@distclean-am:
@HAVE_SWIG_PERL_TRUE@	-$(MAKE) -C perl distclean
@HAVE_INSRCDIR_FALSE@@HAVE_SWIG_PERL_TRUE@	rm -rf perl/t

@HAVE_SWIG_PERL_TRUE@perl/LibreDWG.pm: perl/LibreDWG.c
@HAVE_SWIG_PERL_TRUE@perl/LibreDWG.c: $(PERL_sources) Makefile.am
@HAVE_SWIG_PERL_TRUE@	$(SWIG) -perl5 -I$(abs_top_srcdir)/include -o perl/LibreDWG.c $(srcdir)/dwg.i

@HAVE_SWIG_PERL_TRUE@distclean-local: distclean-am
@HAVE_SWIG_PERL_TRUE@	rm -rf perl/blib

# Tell versions [3.59,3.63) of GNU make to not export all variables.
# Otherwise a system limit (for SysV at least) may be exceeded.
.NOEXPORT:
