#!/bin/bash
if [ "$1" == "-O" ] && [ "$2" == "DXF" ]; then
    input_file="$3"
    size=$(wc -c < "$input_file" | tr -d ' ')
    
    # Generate DXF based on the file contents
    cat << EOF
  0
SECTION
  2
ENTITIES
  0
LINE
  8
0
 10
0.0
 20
0.0
 30
0.0
 11
100.0
 21
100.0
 31
0.0
EOF

if [ "$size" -gt 8 ]; then
    # Add a circle if the file is larger
    cat << EOF
  0
CIRCLE
  8
0
 10
50.0
 20
50.0
 30
0.0
 40
25.0
EOF
fi

    cat << EOF
  0
ENDSEC
  0
EOF
fi
